# programs/font_render_test.cyr â€” HOST harness to eyeball the blockfont (programs/
# blockfont.cyr). Bakes the font, renders a string through dhanchaâ†’rekhaâ†’sadish,
# and dumps the BGRA surface to a file for a pythonâ†’PNG look. Host only (no --agnos).

include "src/lib.cyr"
include "programs/blockfont.cyr"

fn main(): i64 {
    alloc_init();
    # chars available in the font (extend bf_letter to add more)
    var chars = alloc(16 * 8);
    var s = "SAVEHLTCUNFI";           # the glyph set we author (order = gid order)
    var n = strlen(s);
    var i = 0;
    while (i < n) { store64(chars + i * 8, load8(s + i)); i = i + 1; }
    var font = bf_build_font(chars, n);
    if (font == 0) { var fe = "font_render_test: font_open FAILED\n"; syscall(1, 1, fe, strlen(fe)); return 1; }

    var w = 560; var h = 80;
    var root = dh_widget_new(WINDOW);
    dh_widget_set_layout(root, BOX_V);
    dh_widget_set_bg(root, sd_rgb(30, 30, 38));
    var lbl = dh_widget_new(LABEL);
    dh_widget_set_pref(lbl, 0, 48);
    var txt = "SAVE HALT";
    dh_widget_set_text(lbl, txt);
    dh_widget_add_child(root, lbl);

    var surf = dh_surface_new(w, h);
    dh_surface_set_root(surf, root);
    dh_layout_apply(root, w, h);
    var sds = dh_surface_render(surf, font);

    var pix = sd_surface_pixels(sds);
    var path = "/tmp/claude-1000/-home-macro-Repos-agnosticos/47a0fc83-d217-4059-a644-5fc638dfee33/scratchpad/font.bin";
    var fd = syscall(2, path, 577, 420);
    if (fd >= 0) { syscall(1, fd, pix, w * h * 4); syscall(3, fd); }
    var ok = "font_render_test: dumped 560x80 BGRA\n"; syscall(1, 1, ok, strlen(ok));
    return 0;
}

fn _entry(): i64 { var r = main(); syscall(60, r); return 0; }
_entry();
