# programs/font_render_test.cyr — HOST harness for dh_draw_text's DEFAULT text path:
# the kashi VGA 8x16 system font (full CP437), blitted directly (font = 0). Renders a
# few labels and dumps the BGRA surface to a file for a python→PNG eyeball. Host only.

include "src/lib.cyr"

fn main(): i64 {
    alloc_init();
    var w = 760; var h = 150;
    var root = dh_widget_new(WINDOW);
    dh_widget_set_layout(root, BOX_V);
    dh_widget_set_bg(root, sd_rgb(28, 28, 36));
    var l1 = dh_widget_new(LABEL); dh_widget_set_pref(l1, 0, 40);
    var t1 = "Hello, AGNOS! crab the file manager"; dh_widget_set_text(l1, t1);
    dh_widget_add_child(root, l1);
    var l2 = dh_widget_new(LABEL); dh_widget_set_pref(l2, 0, 40);
    var t2 = "src/main.cyr   README.md   0123456789"; dh_widget_set_text(l2, t2);
    dh_widget_add_child(root, l2);
    var l3 = dh_widget_new(LABEL); dh_widget_set_pref(l3, 0, 40);
    var t3 = "The quick brown fox jumps over 12 dogs."; dh_widget_set_text(l3, t3);
    dh_widget_add_child(root, l3);

    var surf = dh_surface_new(w, h);
    dh_surface_set_root(surf, root);
    dh_layout_apply(root, w, h);
    var sds = dh_surface_render(surf, 0);      # font = 0 → the kashi bitmap system font

    var pix = sd_surface_pixels(sds);
    var path = "/tmp/claude-1000/-home-macro-Repos-agnosticos/47a0fc83-d217-4059-a644-5fc638dfee33/scratchpad/font.bin";
    var fd = syscall(2, path, 577, 420);
    if (fd >= 0) { syscall(1, fd, pix, w * h * 4); syscall(3, fd); }
    var ok = "font_render_test: rendered kashi text (font=0)\n"; syscall(1, 1, ok, strlen(ok));
    return 0;
}

fn _entry(): i64 { var r = main(); syscall(60, r); return 0; }
_entry();
