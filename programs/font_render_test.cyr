# programs/font_render_test.cyr — HOST harness to bake a small blocky rekha font
# and eyeball it. Builds a synthetic SFNT (head/maxp/loca/glyf/cmap-fmt4) with a
# handful of single-contour letters authored as on-curve polygons (long-form glyf:
# every flag 0x01, i16 x then i16 y deltas), renders a word through dhancha→rekha→
# sadish, and dumps the BGRA surface to a file for a python→PNG eyeball. Host only.

include "src/lib.cyr"

fn put_u16(buf, off, v): i64 { store8(buf + off, (v >> 8) & 0xFF); store8(buf + off + 1, v & 0xFF); return 0; }
fn put_u32(buf, off, v): i64 { put_u16(buf, off, (v >> 16) & 0xFFFF); put_u16(buf, off + 2, v & 0xFFFF); return 0; }
fn put_i16(buf, off, v): i64 { return put_u16(buf, off, v & 0xFFFF); }   # two's-complement 16-bit

# Emit a single-contour glyph at goff from n on-curve points (cx[i],cy[i] in glyph
# space, y-up). Long form: numContours=1, bbox, endPts=[n-1], instrLen=0, n flag
# bytes (0x01), n i16 x-deltas, n i16 y-deltas. Returns the glyph byte length.
fn emit_glyph(buf, goff, cx, cy, n): i64 {
    put_u16(buf, goff + 0, 1);
    var xmin = 32767; var ymin = 32767; var xmax = 0 - 32768; var ymax = 0 - 32768;
    var i = 0;
    while (i < n) {
        var x = load64(cx + i * 8); var y = load64(cy + i * 8);
        if (x < xmin) { xmin = x; }
        if (x > xmax) { xmax = x; }
        if (y < ymin) { ymin = y; }
        if (y > ymax) { ymax = y; }
        i = i + 1;
    }
    put_i16(buf, goff + 2, xmin); put_i16(buf, goff + 4, ymin);
    put_i16(buf, goff + 6, xmax); put_i16(buf, goff + 8, ymax);
    put_u16(buf, goff + 10, n - 1);
    put_u16(buf, goff + 12, 0);
    var p = goff + 14;
    i = 0;
    while (i < n) { store8(buf + p, 0x01); p = p + 1; i = i + 1; }
    var prev = 0; i = 0;
    while (i < n) { var x = load64(cx + i * 8); put_i16(buf, p, x - prev); p = p + 2; prev = x; i = i + 1; }
    prev = 0; i = 0;
    while (i < n) { var y = load64(cy + i * 8); put_i16(buf, p, y - prev); p = p + 2; prev = y; i = i + 1; }
    return p - goff;
}

# helper: append point (x,y) into parallel coord arrays at index *pn
fn pt(cx, cy, pn, x, y): i64 { var i = load64(pn); store64(cx + i * 8, x); store64(cy + i * 8, y); store64(pn, i + 1); return 0; }

# Author letter `ch` into cx/cy (returns point count). Blocky, em=1000, y-up,
# baseline 0 / cap 700, stroke ~130. Covers T I L E H (enough for "TITLE").
fn letter(ch, cx, cy): i64 {
    var n = 0; var pn = &n;
    if (ch == 0x49) {                       # 'I' — vertical bar
        pt(cx, cy, pn, 200, 0); pt(cx, cy, pn, 340, 0); pt(cx, cy, pn, 340, 700); pt(cx, cy, pn, 200, 700);
    }
    if (ch == 0x54) {                       # 'T' — top bar + stem
        pt(cx, cy, pn, 120, 570); pt(cx, cy, pn, 120, 700); pt(cx, cy, pn, 600, 700); pt(cx, cy, pn, 600, 570);
        pt(cx, cy, pn, 430, 570); pt(cx, cy, pn, 430, 0);   pt(cx, cy, pn, 290, 0);   pt(cx, cy, pn, 290, 570);
    }
    if (ch == 0x4C) {                       # 'L'
        pt(cx, cy, pn, 170, 0); pt(cx, cy, pn, 560, 0); pt(cx, cy, pn, 560, 130); pt(cx, cy, pn, 300, 130);
        pt(cx, cy, pn, 300, 700); pt(cx, cy, pn, 170, 700);
    }
    if (ch == 0x45) {                       # 'E'
        pt(cx, cy, pn, 170, 0); pt(cx, cy, pn, 560, 0); pt(cx, cy, pn, 560, 130); pt(cx, cy, pn, 300, 130);
        pt(cx, cy, pn, 300, 290); pt(cx, cy, pn, 520, 290); pt(cx, cy, pn, 520, 420); pt(cx, cy, pn, 300, 420);
        pt(cx, cy, pn, 300, 570); pt(cx, cy, pn, 560, 570); pt(cx, cy, pn, 560, 700); pt(cx, cy, pn, 170, 700);
    }
    if (ch == 0x46) {                       # 'F' — left stem + top bar + middle arm
        pt(cx, cy, pn, 170, 0); pt(cx, cy, pn, 300, 0); pt(cx, cy, pn, 300, 290); pt(cx, cy, pn, 520, 290);
        pt(cx, cy, pn, 520, 420); pt(cx, cy, pn, 300, 420); pt(cx, cy, pn, 300, 570); pt(cx, cy, pn, 560, 570);
        pt(cx, cy, pn, 560, 700); pt(cx, cy, pn, 170, 700);
    }
    if (ch == 0x48) {                       # 'H'
        pt(cx, cy, pn, 170, 0); pt(cx, cy, pn, 300, 0); pt(cx, cy, pn, 300, 290); pt(cx, cy, pn, 430, 290);
        pt(cx, cy, pn, 430, 0); pt(cx, cy, pn, 560, 0); pt(cx, cy, pn, 560, 700); pt(cx, cy, pn, 430, 700);
        pt(cx, cy, pn, 430, 420); pt(cx, cy, pn, 300, 420); pt(cx, cy, pn, 300, 700); pt(cx, cy, pn, 170, 700);
    }
    return n;
}

# Build a 5-table font (head/maxp/loca/glyf/cmap-fmt4) covering chars[]. Glyph i+1
# = letter(chars[i]); gid 0 = .notdef (empty). Returns the font buffer.
fn build_font(chars, nch): i64 {
    var buf = alloc(8192);
    memset(buf, 0, 8192);
    var ntab = 5;
    var head = 12 + ntab * 16;              # tables laid out after the directory
    var maxp = head + 54;
    var loca = maxp + 32;
    var nglyph = nch + 1;
    var glyf = loca + (nglyph + 1) * 2;      # short loca: (nglyph+1) u16
    # --- glyf + loca ---
    var cx = alloc(64 * 8); var cy = alloc(64 * 8);
    var goff = glyf;
    put_u16(buf, loca + 0, 0);               # loca[0] = 0 (.notdef empty)
    put_u16(buf, loca + 2, 0);               # loca[1] = 0 -> glyph1 starts at 0
    var gi = 0;
    while (gi < nch) {
        var np = letter(load64(chars + gi * 8), cx, cy);
        var glen = emit_glyph(buf, goff, cx, cy, np);
        goff = goff + glen;
        put_u16(buf, loca + (gi + 2) * 2, (goff - glyf) / 2);   # loca entries are /2 (short)
        gi = gi + 1;
    }
    var glyf_len = goff - glyf;
    # --- cmap fmt4: one single-char segment per letter + 0xFFFF terminator ---
    var cmap = goff;
    put_u16(buf, cmap + 0, 0); put_u16(buf, cmap + 2, 1);        # version, numTables
    put_u16(buf, cmap + 4, 3); put_u16(buf, cmap + 6, 1);        # platform 3, enc 1
    put_u32(buf, cmap + 8, 12);                                  # offset to subtable
    var s = cmap + 12;
    var seg = nch + 1;                                           # +1 terminator
    put_u16(buf, s + 0, 4);                                      # format 4
    put_u16(buf, s + 2, 16 + seg * 8);                          # length
    put_u16(buf, s + 4, 0);                                      # language
    put_u16(buf, s + 6, seg * 2);                               # segCountX2
    put_u16(buf, s + 8, 0); put_u16(buf, s + 10, 0); put_u16(buf, s + 12, 0);  # search hints (unused by rekha)
    var endc = s + 14;
    var startc = endc + seg * 2 + 2;                            # +2 reservedPad
    var iddelta = startc + seg * 2;
    var idrange = iddelta + seg * 2;
    # format 4 REQUIRES segments in ascending endCode order — sort (char→gid) pairs
    # by char while the glyph table keeps insertion order (gid = chars index + 1).
    var sch = alloc(nch * 8); var sgid = alloc(nch * 8);
    var q = 0;
    while (q < nch) { store64(sch + q * 8, load64(chars + q * 8)); store64(sgid + q * 8, q + 1); q = q + 1; }
    var a = 1;
    while (a < nch) {
        var kc = load64(sch + a * 8); var kg = load64(sgid + a * 8);
        var b = a - 1; var done = 0;
        while ((b >= 0) && (done == 0)) {
            if (load64(sch + b * 8) > kc) {
                store64(sch + (b + 1) * 8, load64(sch + b * 8)); store64(sgid + (b + 1) * 8, load64(sgid + b * 8));
                b = b - 1;
            } else { done = 1; }
        }
        store64(sch + (b + 1) * 8, kc); store64(sgid + (b + 1) * 8, kg);
        a = a + 1;
    }
    var ci = 0;
    while (ci < nch) {
        var c = load64(sch + ci * 8); var gid = load64(sgid + ci * 8);
        put_u16(buf, endc + ci * 2, c);
        put_u16(buf, startc + ci * 2, c);
        put_u16(buf, iddelta + ci * 2, (gid - c) & 0xFFFF);    # gid = c + delta
        put_u16(buf, idrange + ci * 2, 0);
        ci = ci + 1;
    }
    put_u16(buf, endc + nch * 2, 0xFFFF);
    put_u16(buf, startc + nch * 2, 0xFFFF);
    put_u16(buf, iddelta + nch * 2, 1);
    put_u16(buf, idrange + nch * 2, 0);
    var cmap_len = (16 + seg * 8) + 12;
    # --- head + maxp ---
    put_u16(buf, head + 18, 1000);           # unitsPerEm
    put_u16(buf, head + 50, 0);              # indexToLocFormat = short
    put_u16(buf, maxp + 4, nglyph);          # numGlyphs
    # --- directory ---
    put_u32(buf, 0, 0x00010000); put_u16(buf, 4, ntab);
    put_u32(buf, 12 + 0,  0x68656164); put_u32(buf, 12 + 8,  head); put_u32(buf, 12 + 12, 54);
    put_u32(buf, 28 + 0,  0x6D617870); put_u32(buf, 28 + 8,  maxp); put_u32(buf, 28 + 12, 32);
    put_u32(buf, 44 + 0,  0x6C6F6361); put_u32(buf, 44 + 8,  loca); put_u32(buf, 44 + 12, (nglyph + 1) * 2);
    put_u32(buf, 60 + 0,  0x676C7966); put_u32(buf, 60 + 8,  glyf); put_u32(buf, 60 + 12, glyf_len);
    put_u32(buf, 76 + 0,  0x636D6170); put_u32(buf, 76 + 8,  cmap); put_u32(buf, 76 + 12, cmap_len);
    return buf;
}

fn main(): i64 {
    alloc_init();
    var chars = alloc(8 * 8);
    store64(chars + 0, 0x46); store64(chars + 8, 0x49); store64(chars + 16, 0x4C); store64(chars + 24, 0x45);  # F I L E
    var m1 = "stage: pre-build_font\n"; syscall(1, 1, m1, strlen(m1));
    var raw = build_font(chars, 4);
    var font = rekha_font_open(raw, 8192);     # wrap the SFNT bytes into a RekhaFont
    if (font == 0) { var fe = "font_render_test: rekha_font_open FAILED\n"; syscall(1, 1, fe, strlen(fe)); return 1; }
    var m2 = "stage: font built + opened\n"; syscall(1, 1, m2, strlen(m2));
    var g = rekha_char_to_glyph(font, 0x49);   # 'I' → expect gid 2 (chars = T I L E H)
    var gm = "  cmap 'I' -> gid "; syscall(1, 1, gm, strlen(gm));
    var db = alloc(2); store8(db, 48 + (g & 0x0F)); store8(db + 1, 10); syscall(1, 1, db, 2);

    var w = 320; var h = 80;
    var root = dh_widget_new(WINDOW);
    dh_widget_set_layout(root, BOX_V);
    dh_widget_set_bg(root, sd_rgb(30, 30, 38));
    var lbl = dh_widget_new(LABEL);
    dh_widget_set_pref(lbl, 0, 48);
    var txt = "FILE";
    dh_widget_set_text(lbl, txt);
    dh_widget_add_child(root, lbl);

    var surf = dh_surface_new(w, h);
    dh_surface_set_root(surf, root);
    dh_layout_apply(root, w, h);
    var m3 = "stage: pre-render\n"; syscall(1, 1, m3, strlen(m3));
    var sds = dh_surface_render(surf, font);
    var m4 = "stage: rendered\n"; syscall(1, 1, m4, strlen(m4));

    # dump BGRA buffer to a file for python→PNG
    var pix = sd_surface_pixels(sds);
    var path = "/tmp/claude-1000/-home-macro-Repos-agnosticos/47a0fc83-d217-4059-a644-5fc638dfee33/scratchpad/font.bin";
    var fd = syscall(2, path, 577, 420);     # open O_WRONLY|O_CREAT|O_TRUNC, 0644
    if (fd >= 0) { syscall(1, fd, pix, w * h * 4); syscall(3, fd); }
    var ok = "font_render_test: rendered TITLE + dumped 320x80 BGRA\n";
    syscall(1, 1, ok, strlen(ok));
    return 0;
}

fn _entry(): i64 { var r = main(); syscall(60, r); return 0; }
_entry();
