# --- error.cyr ---

# @public — stable API surface for dhancha error handling.
# error.cyr — dhancha widget-toolkit error codes + Result helpers.
#
# DhanchaErr is a 16-byte record: a consumer (a desktop app, or a
# higher toolkit layer) can map a toolkit failure cleanly onto its own
# error domain. Error codes are integer constants; for errors that
# carry context (a message pointer), use dhancha_err_new(code, msg).
#
# DhanchaErr struct layout (16 bytes):
#   +0: code    — error code constant (one of the DHANCHA_* below)
#   +8: detail  — pointer to detail string (or 0)

# ================================================================
# Error code constants
# ================================================================

enum DhanchaErrCode {
    DHANCHA_OK              = 0;   # no error
    DHANCHA_ERR_OOM        = 1;   # allocation failed
    DHANCHA_ERR_BAD_WIDGET = 2;   # null / malformed widget handle or kind
    DHANCHA_ERR_NO_SURFACE = 3;   # no client surface / present target
    DHANCHA_ERR_LAYOUT     = 4;   # layout measure/arrange could not resolve
    DHANCHA_ERR_UNSUPPORTED = 5;  # valid request dhancha can't service yet
    DHANCHA_ERR_OTHER      = 99;  # catch-all
}

# ================================================================
# DhanchaErr struct
# ================================================================

# Create a DhanchaErr with code and an optional detail string (0 = none).
fn dhancha_err_new(code, detail): i64 {
    var e = alloc(16);
    store64(e, code);
    store64(e + 8, detail);
    return e;
}

# Create a DhanchaErr with code only (no detail).
fn dhancha_err(code): i64 {
    return dhancha_err_new(code, 0);
}

# Get the error code.
fn dhancha_err_code(e): i64 {
    return load64(e);
}

# Get the detail string pointer (or 0).
fn dhancha_err_detail(e): i64 {
    return load64(e + 8);
}

# ================================================================
# Error name lookup — returns a cstring (never null).
# ================================================================

fn dhancha_err_name(code): i64 {
    if (code == DHANCHA_OK)              { return "ok"; }
    if (code == DHANCHA_ERR_OOM)         { return "out of memory"; }
    if (code == DHANCHA_ERR_BAD_WIDGET)  { return "bad widget"; }
    if (code == DHANCHA_ERR_NO_SURFACE)  { return "no surface"; }
    if (code == DHANCHA_ERR_LAYOUT)      { return "layout failed"; }
    if (code == DHANCHA_ERR_UNSUPPORTED) { return "unsupported feature"; }
    if (code == DHANCHA_ERR_OTHER)       { return "other error"; }
    return "unknown error";
}

# Print an error name to stderr (fd 2).
fn dhancha_err_print_name(code): i64 {
    var name = dhancha_err_name(code);
    syscall(1, 2, name, strlen(name));
    return 0;
}

# --- widget.cyr ---

# @public — dhancha widget-tree model.
# widget.cyr — DhWidget: the retained-mode widget node.
#
# A DhWidget is the unit of the UI tree. Nodes form a first-child /
# next-sibling tree (the classic space-efficient n-ary tree encoding),
# so a parent holds one child pointer and children chain via siblings.
# Layout (layout.cyr) walks the tree to assign bounds; event dispatch
# (event.cyr) hit-tests it; the surface (surface.cyr) draws it.
#
# DhWidget struct layout (144 bytes, 18 u64 slots):
#   +0:   id            — monotonic widget id (debug / focus routing)
#   +8:   kind          — one of DhWidgetKind
#   +16:  x             — resolved x (layout output)
#   +24:  y             — resolved y
#   +32:  w             — resolved width
#   +40:  h             — resolved height
#   +48:  parent        — parent DhWidget* (0 = root)
#   +56:  first_child   — first child DhWidget* (0 = leaf)
#   +64:  next_sibling  — next sibling under the same parent (0 = last)
#   +72:  layout        — DhLayout mode applied to this node's children
#   +80:  bg            — background color 0x00RRGGBB, or -1 = none
#   +88:  text          — cstring ptr for LABEL / BUTTON, or 0
#   +96:  pref_w        — requested width (layout hint)
#   +104: pref_h        — requested height
#   +112: handler       — bubble-phase handler fnptr `handler(wgt, ev) -> consumed`, or 0
#   +120: userdata      — opaque app context the handler reads back, or 0
#   +128: capture_h     — capture-phase handler fnptr (fires root->target first), or 0
#   +136: flags         — bitmask: DH_FLAG_DRAGGABLE | DH_FLAG_DROP_TARGET
#   +144: flex          — flex weight for BOX layout (0 = fixed, use pref size)
#   +152: pad           — uniform padding inside this container (px)
#   +160: gap           — spacing between this container's children (px)
#   +168: align         — cross-axis align-self (DhAlign; 0 = STRETCH)

enum DhWidgetKind {
    WINDOW    = 0;
    BOX       = 1;
    LABEL     = 2;
    BUTTON    = 3;
    TEXTINPUT = 4;
}

# Field offsets (bytes) into a DhWidget record.
enum DhWidgetField {
    DH_W_ID           = 0;
    DH_W_KIND         = 8;
    DH_W_X            = 16;
    DH_W_Y            = 24;
    DH_W_W            = 32;
    DH_W_H            = 40;
    DH_W_PARENT       = 48;
    DH_W_FIRST_CHILD  = 56;
    DH_W_NEXT_SIBLING = 64;
    DH_W_LAYOUT       = 72;    # DhLayout mode applied to this node's children
    DH_W_BG           = 80;    # background color 0x00RRGGBB, or -1 = none
    DH_W_TEXT         = 88;    # cstring ptr for LABEL / BUTTON, or 0
    DH_W_PREF_W       = 96;    # requested width (layout hint)
    DH_W_PREF_H       = 104;   # requested height
    DH_W_HANDLER      = 112;   # bubble-phase handler fnptr, or 0
    DH_W_USERDATA     = 120;   # opaque app context for the handler, or 0
    DH_W_CAPTURE_H    = 128;   # capture-phase handler fnptr, or 0
    DH_W_FLAGS        = 136;   # bitmask (DH_FLAG_*)
    DH_W_FLEX         = 144;   # flex weight (0 = fixed)
    DH_W_PAD          = 152;   # uniform content padding (px)
    DH_W_GAP          = 160;   # spacing between children (px)
    DH_W_ALIGN        = 168;   # cross-axis align-self (DhAlign)
}
var DH_WIDGET_SIZE = 176;

# Widget behavior flags (DH_W_FLAGS bitmask).
enum DhWidgetFlag {
    DH_FLAG_DRAGGABLE   = 1;    # a press + drag on this widget starts a drag
    DH_FLAG_DROP_TARGET = 2;    # a drag released over this widget drops onto it
}

# Cross-axis alignment of a child within its BOX container's cross size
# (align-self). STRETCH (the default) fills the cross axis; the others use
# the child's preferred cross size and position it.
enum DhAlign {
    ALIGN_STRETCH = 0;
    ALIGN_START   = 1;
    ALIGN_CENTER  = 2;
    ALIGN_END     = 3;
}

# Monotonic widget-id source. A plain module-global SCALAR (not a `[1]` array —
# module-global `var X[N]` sizing is non-uniform in cyrius, so an 8-byte
# load64/store64 on a `[1]` can read/write out of bounds). A scalar i64 is a
# reliable 8-byte cell accessed directly.
var _dh_next_widget_id = 0;

# Allocate + zero-init a widget of the given kind. Returns a DhWidget*.
# All bounds start at 0 (layout fills them in); tree links start null.
fn dh_widget_new(kind): i64 {
    var wgt = alloc(DH_WIDGET_SIZE);
    var id = _dh_next_widget_id;
    _dh_next_widget_id = id + 1;
    store64(wgt + DH_W_ID, id);
    store64(wgt + DH_W_KIND, kind);
    store64(wgt + DH_W_X, 0);
    store64(wgt + DH_W_Y, 0);
    store64(wgt + DH_W_W, 0);
    store64(wgt + DH_W_H, 0);
    store64(wgt + DH_W_PARENT, 0);
    store64(wgt + DH_W_FIRST_CHILD, 0);
    store64(wgt + DH_W_NEXT_SIBLING, 0);
    store64(wgt + DH_W_LAYOUT, 0);         # NONE
    store64(wgt + DH_W_BG, 0 - 1);         # -1 = no background
    store64(wgt + DH_W_TEXT, 0);
    store64(wgt + DH_W_PREF_W, 0);
    store64(wgt + DH_W_PREF_H, 0);
    store64(wgt + DH_W_HANDLER, 0);        # no bubble handler
    store64(wgt + DH_W_USERDATA, 0);
    store64(wgt + DH_W_CAPTURE_H, 0);      # no capture handler
    store64(wgt + DH_W_FLAGS, 0);          # no flags
    store64(wgt + DH_W_FLEX, 0);           # fixed (not flexible)
    store64(wgt + DH_W_PAD, 0);            # no padding
    store64(wgt + DH_W_GAP, 0);            # no gap
    store64(wgt + DH_W_ALIGN, 0);          # ALIGN_STRETCH
    return wgt;
}

# Append `child` as the last child of `parent`. Sets child.parent and
# links it onto the sibling chain. Returns DHANCHA_OK / an error code.
fn dh_widget_add_child(parent, child): i64 {
    if (parent == 0) { return DHANCHA_ERR_BAD_WIDGET; }
    if (child == 0)  { return DHANCHA_ERR_BAD_WIDGET; }
    store64(child + DH_W_PARENT, parent);
    var head = load64(parent + DH_W_FIRST_CHILD);
    if (head == 0) {
        store64(parent + DH_W_FIRST_CHILD, child);
        return DHANCHA_OK;
    }
    # walk to the last sibling and append
    var cur = head;
    while (load64(cur + DH_W_NEXT_SIBLING) != 0) {
        cur = load64(cur + DH_W_NEXT_SIBLING);
    }
    store64(cur + DH_W_NEXT_SIBLING, child);
    return DHANCHA_OK;
}

# ---- accessors ----------------------------------------------------

fn dh_widget_id(wgt): i64          { return load64(wgt + DH_W_ID); }
fn dh_widget_kind(wgt): i64        { return load64(wgt + DH_W_KIND); }
fn dh_widget_x(wgt): i64           { return load64(wgt + DH_W_X); }
fn dh_widget_y(wgt): i64           { return load64(wgt + DH_W_Y); }
fn dh_widget_w(wgt): i64           { return load64(wgt + DH_W_W); }
fn dh_widget_h(wgt): i64           { return load64(wgt + DH_W_H); }
fn dh_widget_parent(wgt): i64      { return load64(wgt + DH_W_PARENT); }
fn dh_widget_first_child(wgt): i64 { return load64(wgt + DH_W_FIRST_CHILD); }
fn dh_widget_next_sibling(wgt): i64 { return load64(wgt + DH_W_NEXT_SIBLING); }

# Set the resolved bounds (called by the layout pass).
fn dh_widget_set_bounds(wgt, x, y, w, h): i64 {
    if (wgt == 0) { return DHANCHA_ERR_BAD_WIDGET; }
    store64(wgt + DH_W_X, x);
    store64(wgt + DH_W_Y, y);
    store64(wgt + DH_W_W, w);
    store64(wgt + DH_W_H, h);
    return DHANCHA_OK;
}

# ---- style + layout properties ------------------------------------

fn dh_widget_layout(wgt): i64 { return load64(wgt + DH_W_LAYOUT); }
fn dh_widget_bg(wgt): i64     { return load64(wgt + DH_W_BG); }
fn dh_widget_text(wgt): i64   { return load64(wgt + DH_W_TEXT); }
fn dh_widget_pref_w(wgt): i64 { return load64(wgt + DH_W_PREF_W); }
fn dh_widget_pref_h(wgt): i64 { return load64(wgt + DH_W_PREF_H); }

# Set the child-layout mode (DhLayout: NONE / BOX_H / BOX_V / FLEX).
fn dh_widget_set_layout(wgt, mode): i64 {
    if (wgt == 0) { return DHANCHA_ERR_BAD_WIDGET; }
    store64(wgt + DH_W_LAYOUT, mode);
    return DHANCHA_OK;
}

# Set the background color (0x00RRGGBB), or -1 for no background.
fn dh_widget_set_bg(wgt, color): i64 {
    if (wgt == 0) { return DHANCHA_ERR_BAD_WIDGET; }
    store64(wgt + DH_W_BG, color);
    return DHANCHA_OK;
}

# Set the widget's text (a borrowed cstring pointer, or 0).
fn dh_widget_set_text(wgt, text): i64 {
    if (wgt == 0) { return DHANCHA_ERR_BAD_WIDGET; }
    store64(wgt + DH_W_TEXT, text);
    return DHANCHA_OK;
}

# Set the preferred (requested) size, a layout hint.
fn dh_widget_set_pref(wgt, w, h): i64 {
    if (wgt == 0) { return DHANCHA_ERR_BAD_WIDGET; }
    store64(wgt + DH_W_PREF_W, w);
    store64(wgt + DH_W_PREF_H, h);
    return DHANCHA_OK;
}

# ---- event handler + userdata -------------------------------------

fn dh_widget_handler(wgt): i64  { return load64(wgt + DH_W_HANDLER); }
fn dh_widget_userdata(wgt): i64 { return load64(wgt + DH_W_USERDATA); }

# Attach an event-handler function pointer. Take the address with
# `&fn_name` (the fn must be `handler(wgt, ev): i64` returning 1 to
# consume the event, 0 to let it bubble). Pass 0 to clear.
fn dh_widget_set_handler(wgt, fp): i64 {
    if (wgt == 0) { return DHANCHA_ERR_BAD_WIDGET; }
    store64(wgt + DH_W_HANDLER, fp);
    return DHANCHA_OK;
}

# Attach opaque app context the handler can read back via
# dh_widget_userdata (dispatch passes only the widget + event).
fn dh_widget_set_userdata(wgt, ud): i64 {
    if (wgt == 0) { return DHANCHA_ERR_BAD_WIDGET; }
    store64(wgt + DH_W_USERDATA, ud);
    return DHANCHA_OK;
}

# Can this widget take keyboard focus? BUTTON / TEXTINPUT do; structural
# nodes (WINDOW / BOX / LABEL) do not. Click-to-focus consults this.
fn dh_widget_focusable(wgt): i64 {
    if (wgt == 0) { return 0; }
    var k = dh_widget_kind(wgt);
    if (k == BUTTON)    { return 1; }
    if (k == TEXTINPUT) { return 1; }
    return 0;
}

# ---- capture-phase handler ----------------------------------------

fn dh_widget_capture_handler(wgt): i64 { return load64(wgt + DH_W_CAPTURE_H); }

# Attach a capture-phase handler (fires root -> target, BEFORE the bubble
# handlers). Same `handler(wgt, ev): i64` shape; return 1 to consume the
# event (which also cancels the bubble pass). Pass 0 to clear.
fn dh_widget_set_capture_handler(wgt, fp): i64 {
    if (wgt == 0) { return DHANCHA_ERR_BAD_WIDGET; }
    store64(wgt + DH_W_CAPTURE_H, fp);
    return DHANCHA_OK;
}

# ---- behavior flags (drag source / drop target) -------------------

fn dh_widget_flags(wgt): i64 { return load64(wgt + DH_W_FLAGS); }

# Set/clear one flag bit without touching the others.
fn dh_widget_set_flag(wgt, flag, on): i64 {
    if (wgt == 0) { return DHANCHA_ERR_BAD_WIDGET; }
    var f = load64(wgt + DH_W_FLAGS);
    if (on == 0) {
        f = f & (0 - 1 - flag);            # clear: AND with ~flag (two's complement)
    } else {
        f = f | flag;
    }
    store64(wgt + DH_W_FLAGS, f);
    return DHANCHA_OK;
}

fn dh_widget_set_draggable(wgt, on): i64   { return dh_widget_set_flag(wgt, DH_FLAG_DRAGGABLE, on); }
fn dh_widget_set_drop_target(wgt, on): i64 { return dh_widget_set_flag(wgt, DH_FLAG_DROP_TARGET, on); }

fn dh_widget_is_draggable(wgt): i64 {
    if (wgt == 0) { return 0; }
    if ((dh_widget_flags(wgt) & DH_FLAG_DRAGGABLE) != 0) { return 1; }
    return 0;
}

fn dh_widget_is_drop_target(wgt): i64 {
    if (wgt == 0) { return 0; }
    if ((dh_widget_flags(wgt) & DH_FLAG_DROP_TARGET) != 0) { return 1; }
    return 0;
}

# ---- flex / box layout properties ---------------------------------

fn dh_widget_flex(wgt): i64    { return load64(wgt + DH_W_FLEX); }
fn dh_widget_padding(wgt): i64 { return load64(wgt + DH_W_PAD); }
fn dh_widget_gap(wgt): i64     { return load64(wgt + DH_W_GAP); }
fn dh_widget_align(wgt): i64   { return load64(wgt + DH_W_ALIGN); }

# Flex weight: 0 = fixed (takes its pref main-axis size); > 0 = flexible
# (grows to share the container's leftover main-axis space by weight).
fn dh_widget_set_flex(wgt, weight): i64 {
    if (wgt == 0) { return DHANCHA_ERR_BAD_WIDGET; }
    store64(wgt + DH_W_FLEX, weight);
    return DHANCHA_OK;
}

# Uniform padding inset applied to this container's content box.
fn dh_widget_set_padding(wgt, pad): i64 {
    if (wgt == 0) { return DHANCHA_ERR_BAD_WIDGET; }
    store64(wgt + DH_W_PAD, pad);
    return DHANCHA_OK;
}

# Spacing inserted between consecutive children in BOX_H / BOX_V.
fn dh_widget_set_gap(wgt, gap): i64 {
    if (wgt == 0) { return DHANCHA_ERR_BAD_WIDGET; }
    store64(wgt + DH_W_GAP, gap);
    return DHANCHA_OK;
}

# Cross-axis alignment of this child within its container (a DhAlign).
fn dh_widget_set_align(wgt, align): i64 {
    if (wgt == 0) { return DHANCHA_ERR_BAD_WIDGET; }
    store64(wgt + DH_W_ALIGN, align);
    return DHANCHA_OK;
}

# --- layout.cyr ---

# @public — dhancha layout engine.
# layout.cyr — flexbox-style box layout over a DhWidget tree.
#
# The arrange pass walks the tree top-down: each node is assigned a box
# (x, y, w, h), then it arranges its children within its PADDED content
# box according to its DhLayout mode, and recurses. BOX_V (column) and
# BOX_H (row) are flex containers: a child with flex weight 0 takes its
# preferred main-axis size, and children with flex > 0 split the leftover
# main-axis space in proportion to their weights. `gap` separates
# children; `pad` insets the content box; each child's DhAlign positions
# it on the cross axis (STRETCH fills it). NONE is absolute overlay.
#
# Intrinsic measure (dh_measure / dh_layout_fit) computes a widget's
# natural content size bottom-up; inside a flex box a fixed child with no
# preferred main size auto-sizes to its measured content.

# Layout modes a container applies to its children.
enum DhLayout {
    NONE  = 0;   # children keep their own bounds (absolute overlay)
    BOX_H = 1;   # flex row: stack children left→right
    BOX_V = 2;   # flex column: stack children top→bottom
    FLEX  = 3;   # alias of BOX_V (a flex column)
}

# DhRect struct layout (32 bytes): x, y, w, h.
enum DhRectField {
    DH_R_X = 0;
    DH_R_Y = 8;
    DH_R_W = 16;
    DH_R_H = 24;
}

# Allocate a DhRect.
fn dh_rect_new(x, y, w, h): i64 {
    var r = alloc(32);
    store64(r + DH_R_X, x);
    store64(r + DH_R_Y, y);
    store64(r + DH_R_W, w);
    store64(r + DH_R_H, h);
    return r;
}

fn dh_rect_x(r): i64 { return load64(r + DH_R_X); }
fn dh_rect_y(r): i64 { return load64(r + DH_R_Y); }
fn dh_rect_w(r): i64 { return load64(r + DH_R_W); }
fn dh_rect_h(r): i64 { return load64(r + DH_R_H); }

# ---- intrinsic measure --------------------------------------------

# @public — compute `wgt`'s natural content size bottom-up, writing
# (width, height) into the 16-byte `out` buffer. A CHILDLESS widget
# measures to its preferred size — so padding on an empty widget adds
# nothing; use a pref for a spacer. A container's content size derives
# from its measured children per mode (BOX_V: max width, summed heights +
# gaps; BOX_H: summed widths + gaps, max height; NONE: bounding box) plus
# 2*padding; an explicit pref on an axis is an EXACT size and overrides the
# computed content on that axis, so dh_measure and the dh_child_main layout
# path agree — dh_layout_fit never sizes a parent smaller than a pref-
# bearing child (which would otherwise overflow it).
fn dh_measure(wgt, out): i64 {
    if (wgt == 0) {
        store64(out, 0);
        store64(out + 8, 0);
        return DHANCHA_OK;
    }
    var child = dh_widget_first_child(wgt);
    if (child == 0) {
        store64(out, dh_widget_pref_w(wgt));
        store64(out + 8, dh_widget_pref_h(wgt));
        return DHANCHA_OK;
    }
    var pad = dh_widget_padding(wgt);
    var gap = dh_widget_gap(wgt);
    var mode = dh_widget_layout(wgt);
    var cbuf = alloc(16);
    var count = 0;
    var sum_w = 0;
    var sum_h = 0;
    var max_w = 0;
    var max_h = 0;
    while (child != 0) {
        dh_measure(child, cbuf);
        var cw = load64(cbuf);
        var chn = load64(cbuf + 8);
        count = count + 1;
        sum_w = sum_w + cw;
        sum_h = sum_h + chn;
        if (cw > max_w) { max_w = cw; }
        if (chn > max_h) { max_h = chn; }
        child = dh_widget_next_sibling(child);
    }
    var gap_total = 0;
    if (count > 1) { gap_total = (count - 1) * gap; }
    var nat_w = max_w;              # default (NONE = bounding box)
    var nat_h = max_h;
    if (mode == BOX_H) {
        nat_w = sum_w + gap_total;
        nat_h = max_h;
    }
    if (mode == BOX_V) {
        nat_w = max_w;
        nat_h = sum_h + gap_total;
    }
    if (mode == FLEX) {
        nat_w = max_w;
        nat_h = sum_h + gap_total;
    }
    var out_w = nat_w + pad + pad;
    var out_h = nat_h + pad + pad;
    # an explicit pref on an axis is an exact size — it wins over content,
    # matching dh_child_main so measure and layout agree (no fit overflow)
    var pw = dh_widget_pref_w(wgt);
    var ph = dh_widget_pref_h(wgt);
    if (pw != 0) { out_w = pw; }
    if (ph != 0) { out_h = ph; }
    store64(out, out_w);
    store64(out + 8, out_h);
    return DHANCHA_OK;
}

# Convenience: natural width / height only.
fn dh_measure_w(wgt): i64 {
    var m = alloc(16);
    dh_measure(wgt, m);
    return load64(m);
}
fn dh_measure_h(wgt): i64 {
    var m = alloc(16);
    dh_measure(wgt, m);
    return load64(m + 8);
}

# The main-axis size a FIXED child occupies in a box: its preferred main
# size, or — when that is 0 — its measured content size. This is what lets
# a nested container with no explicit size auto-fit its content inside a
# flex parent.
fn dh_child_main(child, vertical): i64 {
    var pm = dh_widget_pref_w(child);
    if (vertical == 1) { pm = dh_widget_pref_h(child); }
    if (pm != 0) { return pm; }
    var m = alloc(16);
    dh_measure(child, m);
    var mm = load64(m);
    if (vertical == 1) { mm = load64(m + 8); }
    return mm;
}

# Arrange a NONE container: children overlay the padded content box, each
# at its preferred size (a 0 dimension fills the content box).
fn dh_layout_none(wgt, x, y, w, h): i64 {
    var pad = dh_widget_padding(wgt);
    var cx = x + pad;
    var cy = y + pad;
    var cw = w - pad - pad;
    var chh = h - pad - pad;
    if (cw < 0) { cw = 0; }
    if (chh < 0) { chh = 0; }
    var child = dh_widget_first_child(wgt);
    while (child != 0) {
        var pw = dh_widget_pref_w(child);
        var ph = dh_widget_pref_h(child);
        if (pw == 0) { pw = cw; }
        if (ph == 0) { ph = chh; }
        dh_layout_at(child, cx, cy, pw, ph);
        child = dh_widget_next_sibling(child);
    }
    return DHANCHA_OK;
}

# Arrange a flex BOX container. `vertical` = 1 for a column (BOX_V: main
# axis = height, cross = width), 0 for a row (BOX_H: main = width, cross =
# height). Fixed children (flex 0) take their pref main size; flex > 0
# children split the leftover main space by weight (the last flex child
# gets the exact remainder so rounding never loses a pixel). `gap`
# separates children; each child is placed on the cross axis per its
# DhAlign (STRETCH fills the cross size).
fn dh_layout_box(wgt, x, y, w, h, vertical): i64 {
    var pad = dh_widget_padding(wgt);
    var gap = dh_widget_gap(wgt);
    var cx = x + pad;
    var cy = y + pad;
    var cw = w - pad - pad;
    var chh = h - pad - pad;
    if (cw < 0) { cw = 0; }
    if (chh < 0) { chh = 0; }

    # main-axis available space
    var main_avail = cw;
    if (vertical == 1) { main_avail = chh; }

    # pass 1: count children, sum fixed main sizes + flex weights
    var count = 0;
    var fixed = 0;
    var flex_total = 0;
    var child = dh_widget_first_child(wgt);
    while (child != 0) {
        count = count + 1;
        var cflex = dh_widget_flex(child);
        if (cflex > 0) {
            flex_total = flex_total + cflex;
        } else {
            fixed = fixed + dh_child_main(child, vertical);
        }
        child = dh_widget_next_sibling(child);
    }
    var total_gap = 0;
    if (count > 1) { total_gap = (count - 1) * gap; }
    var free = main_avail - fixed - total_gap;
    if (free < 0) { free = 0; }

    # pass 2: place children along the main axis
    var pos = cy;
    if (vertical == 0) { pos = cx; }
    var flex_used = 0;
    var flex_seen = 0;
    child = dh_widget_first_child(wgt);
    while (child != 0) {
        var cflex = dh_widget_flex(child);
        var msize = 0;
        if (cflex > 0) {
            flex_seen = flex_seen + cflex;
            # proportional share; the LAST flex child gets the exact
            # remainder so integer rounding never leaves/overshoots pixels
            if (flex_seen == flex_total) {
                msize = free - flex_used;
            } else {
                msize = free * cflex / flex_total;
                flex_used = flex_used + msize;
            }
        } else {
            msize = dh_child_main(child, vertical);
        }
        # cross axis: available + this child's pref cross size
        var cross_avail = cw;
        if (vertical == 0) { cross_avail = chh; }
        var cross_pref = dh_widget_pref_w(child);
        if (vertical == 0) { cross_pref = dh_widget_pref_h(child); }
        var align = dh_widget_align(child);
        var csize = cross_avail;             # STRETCH fills the cross size
        var coff = 0;
        if (align != ALIGN_STRETCH) {
            if (cross_pref == 0) { cross_pref = cross_avail; }
            csize = cross_pref;
            if (csize > cross_avail) { csize = cross_avail; }
            if (align == ALIGN_CENTER) { coff = (cross_avail - csize) / 2; }
            if (align == ALIGN_END) { coff = cross_avail - csize; }
            if (coff < 0) { coff = 0; }
        }
        if (vertical == 1) {
            dh_layout_at(child, cx + coff, pos, csize, msize);
        } else {
            dh_layout_at(child, pos, cy + coff, msize, csize);
        }
        pos = pos + msize + gap;
        child = dh_widget_next_sibling(child);
    }
    return DHANCHA_OK;
}

# Assign `wgt` the box (x, y, w, h), then arrange its children per its
# DhLayout mode and recurse. BOX_V / FLEX = flex column, BOX_H = flex row
# (both honor pad / gap / per-child flex + align); NONE = overlay. A fixed
# child with no pref main size auto-sizes to its measured content.
fn dh_layout_at(wgt, x, y, w, h): i64 {
    if (wgt == 0) { return DHANCHA_ERR_BAD_WIDGET; }
    dh_widget_set_bounds(wgt, x, y, w, h);
    var mode = dh_widget_layout(wgt);
    if (mode == BOX_V) { return dh_layout_box(wgt, x, y, w, h, 1); }
    if (mode == FLEX)  { return dh_layout_box(wgt, x, y, w, h, 1); }
    if (mode == BOX_H) { return dh_layout_box(wgt, x, y, w, h, 0); }
    return dh_layout_none(wgt, x, y, w, h);
}

# @public — lay out `root` within an (avail_w × avail_h) box at origin (0,0).
fn dh_layout_apply(root, avail_w, avail_h): i64 {
    return dh_layout_at(root, 0, 0, avail_w, avail_h);
}

# @public — measure `root`'s natural size, then lay it out at that size
# (origin 0,0). Convenience for a window that shrinks to fit its content.
fn dh_layout_fit(root): i64 {
    var m = alloc(16);
    dh_measure(root, m);
    return dh_layout_at(root, 0, 0, load64(m), load64(m + 8));
}

# --- event.cyr ---

# @public — dhancha input dispatch + event loop.
# event.cyr — this module OWNS the input-dispatch role.
#
# Input (keyboard / pointer) arrives from the aethersafha compositor over
# the native display-protocol connection as DhEvents. dh_dispatch resolves a
# target (the focused widget for keys, the widget under the pointer for
# clicks) and BUBBLES the event up the parent chain, invoking each node's
# handler until one CONSUMES it. dh_run pumps a DhQueue of events and
# dispatches them until the queue drains or a handler calls dh_quit.
#
# Wire model (the compositor input convention): a pointer BUTTON
# event carries (button, state) but NOT coordinates — the compositor
# tracks position from MOTION events. So dhancha keeps the current
# pointer position (updated on POINTER_MOVE) and hit-tests button/drag
# events against it, not against the button event's payload.
#
# The compositor-fd source (decode the native protocol's input wire bytes
# into DhEvents and pump the transport) is a later bite (see CHANGELOG); the
# DhQueue is the seam it will feed. Until then a caller (or a test) posts
# DhEvents into the queue directly, keeping the whole dispatch path usable.

# The kinds of input event the toolkit routes.
enum DhEventKind {
    KEY           = 0;   # keyboard key: keysym / codepoint in `a`, mods in `b`
    POINTER_MOVE  = 1;   # pointer motion to (x=`a`, y=`b`)
    POINTER_BTN   = 2;   # pointer button: code in `a`, state in `b` (0=release,1=press)
    FOCUS         = 3;   # focus enter/leave
    DRAG          = 4;   # raw drag phase (hit-tests at the tracked pointer)
    POINTER_ENTER = 5;   # synthesized: pointer entered a widget (hover)
    POINTER_LEAVE = 6;   # synthesized: pointer left a widget (hover)
    ACTIVATE      = 7;   # synthesized: click / keyboard activation of a widget
    DRAG_START    = 8;   # synthesized: a drag began on a draggable widget (to source)
    DRAG_MOVE     = 9;   # synthesized: pointer moved while dragging (to source)
    DRAG_DROP     = 10;  # synthesized: drag released over a drop target
    DRAG_END      = 11;  # synthesized: drag finished (to source)
}

# Well-known key codes the toolkit acts on itself (values are ASCII /
# Unicode codepoints, matching the puka keymap's sym space).
enum DhKey {
    DH_KEY_TAB    = 9;
    DH_KEY_ENTER  = 10;
    DH_KEY_RETURN = 13;
    DH_KEY_SPACE  = 32;
}

# Event propagation phase (DH_E_PHASE): a dispatched event runs a CAPTURE
# pass (root -> target, capture handlers) then a BUBBLE pass (target ->
# root, bubble handlers). A handler reads dh_event_phase to tell them apart.
enum DhPhase {
    DH_PHASE_CAPTURE = 1;
    DH_PHASE_BUBBLE  = 2;
}

# Pointer travel (Manhattan distance from the press point) before a press
# on a draggable widget is promoted to a drag, so a jittery click doesn't
# accidentally start one.
var DH_DRAG_THRESHOLD = 4;

# DhEvent struct layout (56 bytes):
#   +0:  kind    — one of DhEventKind
#   +8:  a       — primary payload (keysym / x / button code)
#   +16: b       — secondary payload (mods / y / button state)
#   +24: target  — resolved target DhWidget* (0 = unrouted): the ORIGINAL
#                  hit/focus node (propagation still reports currentTarget to
#                  each handler as its first arg)
#   +32: consumed — 1 once a handler claims it (stops propagation)
#   +40: phase   — DH_PHASE_CAPTURE / _BUBBLE during propagation (0 otherwise)
#   +48: source  — drag source DhWidget* on DRAG_* events (0 otherwise)
enum DhEventField {
    DH_E_KIND     = 0;
    DH_E_A        = 8;
    DH_E_B        = 16;
    DH_E_TARGET   = 24;
    DH_E_CONSUMED = 32;
    DH_E_PHASE    = 40;
    DH_E_SOURCE   = 48;
}

# Currently-focused widget for keyboard routing. A plain module-global
# SCALAR (NOT a `var X[1]` array — module-global `var X[N]` sizing is
# non-uniform in cyrius, so an 8-byte load64/store64 on a `[1]` can read
# or write out of bounds). A scalar i64 is a reliable 8-byte cell.
var _dh_focus = 0;

# Last known pointer position (set by POINTER_MOVE; button/drag events
# hit-test against this, matching the compositor wire model).
var _dh_ptr_x = 0;
var _dh_ptr_y = 0;

# Widget currently under the pointer (hover), and the widget that received
# the last still-unreleased press (for click / ACTIVATE synthesis).
var _dh_hover = 0;
var _dh_press = 0;

# Press origin (for the drag threshold) and the active drag source
# (0 = no drag in progress).
var _dh_press_x = 0;
var _dh_press_y = 0;
var _dh_drag_src = 0;

# The event-loop run flag. dh_run sets it; dh_quit clears it.
var _dh_running = 0;

# Allocate a DhEvent of `kind` with zeroed payload.
fn dh_event_new(kind): i64 {
    var ev = alloc(56);
    store64(ev + DH_E_KIND, kind);
    store64(ev + DH_E_A, 0);
    store64(ev + DH_E_B, 0);
    store64(ev + DH_E_TARGET, 0);
    store64(ev + DH_E_CONSUMED, 0);
    store64(ev + DH_E_PHASE, 0);
    store64(ev + DH_E_SOURCE, 0);
    return ev;
}

fn dh_event_kind(ev): i64     { return load64(ev + DH_E_KIND); }
fn dh_event_a(ev): i64        { return load64(ev + DH_E_A); }
fn dh_event_b(ev): i64        { return load64(ev + DH_E_B); }
fn dh_event_target(ev): i64   { return load64(ev + DH_E_TARGET); }
fn dh_event_consumed(ev): i64 { return load64(ev + DH_E_CONSUMED); }
fn dh_event_phase(ev): i64    { return load64(ev + DH_E_PHASE); }
fn dh_event_source(ev): i64   { return load64(ev + DH_E_SOURCE); }

# Set the payload fields.
fn dh_event_set_payload(ev, a, b): i64 {
    store64(ev + DH_E_A, a);
    store64(ev + DH_E_B, b);
    return DHANCHA_OK;
}

# Set / get the keyboard focus target.
fn dh_focus_set(wgt): i64 { _dh_focus = wgt; return DHANCHA_OK; }
fn dh_focus_get(): i64    { return _dh_focus; }

# Widget currently under the pointer (0 = none).
fn dh_hover_get(): i64 { return _dh_hover; }

# Clear all transient input state (focus, hover, press). Apps call this
# when swapping the widget tree (a new window / scene) so a stale pointer
# can't route into a torn-down tree.
fn dh_reset_input(): i64 {
    _dh_focus = 0;
    _dh_hover = 0;
    _dh_press = 0;
    _dh_drag_src = 0;
    return DHANCHA_OK;
}

# Current pointer position (last POINTER_MOVE).
fn dh_pointer_x(): i64 { return _dh_ptr_x; }
fn dh_pointer_y(): i64 { return _dh_ptr_y; }

# Hit-test: which widget contains point (px, py)? Depth-first, last
# match wins (children paint over parents). Returns a DhWidget* or 0.
#
# TODO (see CHANGELOG): honor z-order + clipping + input-transparency. This
# is a plain contains-point walk of the laid-out bounds.
fn dh_hit_test(root, px, py): i64 {
    if (root == 0) { return 0; }
    var hit = 0;
    var rx = dh_widget_x(root);
    var ry = dh_widget_y(root);
    var rw = dh_widget_w(root);
    var rh = dh_widget_h(root);
    if (px >= rx) { if (py >= ry) { if (px < rx + rw) { if (py < ry + rh) {
                    hit = root;
                } } } }
    # recurse; a deeper hit overrides
    var child = dh_widget_first_child(root);
    while (child != 0) {
        var ch = dh_hit_test(child, px, py);
        if (ch != 0) { hit = ch; }
        child = dh_widget_next_sibling(child);
    }
    return hit;
}

# Bubble `ev` up the parent chain starting at `target`: invoke each
# node's handler (if any); the first handler that returns 1 CONSUMES the
# event and stops propagation (sets DH_E_CONSUMED). Handlers receive
# (currentTarget, ev); the original hit/focus node is ev's DH_E_TARGET.
# A null handler ptr is skipped (fncall on 0 would crash).
fn dh_bubble(target, ev): i64 {
    var node = target;
    while (node != 0) {
        var fp = dh_widget_handler(node);
        if (fp != 0) {
            var consumed = fncall2(fp, node, ev);
            if (consumed == 1) {
                store64(ev + DH_E_CONSUMED, 1);
                return DHANCHA_OK;
            }
        }
        node = dh_widget_parent(node);
    }
    return DHANCHA_OK;
}

# Full two-phase propagation, the router dispatch uses: a CAPTURE pass
# (root -> target, invoking each node's capture handler) then a BUBBLE pass
# (target -> root, invoking each node's bubble handler). The first handler
# in EITHER pass to return 1 CONSUMES the event (sets DH_E_CONSUMED) and
# stops all further propagation — a capture handler can thus intercept an
# event before the target's bubble handler ever sees it. Handlers get
# (currentTarget, ev); dh_event_phase says which pass. Null slots skipped.
fn dh_propagate(target, ev): i64 {
    if (target == 0) { return DHANCHA_OK; }
    # collect the chain target..root into buf (buf[0]=target .. buf[n-1]=root)
    var cap = 256;
    var buf = alloc(cap * 8);
    var n = 0;
    var node = target;
    while (node != 0) {
        if (n < cap) {
            store64(buf + n * 8, node);
            n = n + 1;
        }
        node = dh_widget_parent(node);
    }
    # capture pass: root -> target (indices n-1 .. 0)
    store64(ev + DH_E_PHASE, DH_PHASE_CAPTURE);
    var i = n - 1;
    while (i >= 0) {
        var wc = load64(buf + i * 8);
        var fc = dh_widget_capture_handler(wc);
        if (fc != 0) {
            if (fncall2(fc, wc, ev) == 1) {
                store64(ev + DH_E_CONSUMED, 1);
                return DHANCHA_OK;
            }
        }
        i = i - 1;
    }
    # bubble pass: target -> root (indices 0 .. n-1)
    store64(ev + DH_E_PHASE, DH_PHASE_BUBBLE);
    var j = 0;
    while (j < n) {
        var wb = load64(buf + j * 8);
        var fb = dh_widget_handler(wb);
        if (fb != 0) {
            if (fncall2(fb, wb, ev) == 1) {
                store64(ev + DH_E_CONSUMED, 1);
                return DHANCHA_OK;
            }
        }
        j = j + 1;
    }
    return DHANCHA_OK;
}

# ---- higher-level synthesis helpers --------------------------------

# Emit a fresh synthetic event of `kind` targeted at `target` and bubble
# it. Used for POINTER_ENTER / POINTER_LEAVE / ACTIVATE, which the toolkit
# DERIVES from raw motion/button/key events rather than receiving off the
# wire. No-op on a null target.
fn dh_emit(target, kind): i64 {
    if (target == 0) { return DHANCHA_OK; }
    var ev = dh_event_new(kind);
    store64(ev + DH_E_TARGET, target);
    dh_propagate(target, ev);
    return DHANCHA_OK;
}

# Update the hovered widget; on a boundary crossing emit POINTER_LEAVE to
# the widget left and POINTER_ENTER to the widget entered.
fn dh_update_hover(target): i64 {
    if (target == _dh_hover) { return DHANCHA_OK; }
    if (_dh_hover != 0) { dh_emit(_dh_hover, POINTER_LEAVE); }
    _dh_hover = target;
    if (target != 0) { dh_emit(target, POINTER_ENTER); }
    return DHANCHA_OK;
}

# Pre-order (DFS) collect of focusable widgets into `buf` (up to `cap`
# slots). Returns the running count, threaded through the return value so
# no address-of-a-local is needed.
fn dh_collect_focusable(node, buf, count, cap): i64 {
    if (node == 0) { return count; }
    var c = count;
    if (dh_widget_focusable(node) == 1) {
        if (c < cap) {
            store64(buf + c * 8, node);
            c = c + 1;
        }
    }
    var child = dh_widget_first_child(node);
    while (child != 0) {
        c = dh_collect_focusable(child, buf, c, cap);
        child = dh_widget_next_sibling(child);
    }
    return c;
}

# Move keyboard focus to the next (backward==0) or previous (backward!=0)
# focusable widget in pre-order, wrapping. With no current focus, forward
# picks the first and backward the last. Caps at 256 focusables (a UI with
# more is beyond this toolkit's current scope).
fn dh_focus_advance(root, backward): i64 {
    var cap = 256;
    var buf = alloc(cap * 8);
    var count = dh_collect_focusable(root, buf, 0, cap);
    if (count == 0) { return DHANCHA_OK; }
    var cur = dh_focus_get();
    var idx = 0 - 1;
    var i = 0;
    while (i < count) {
        if (load64(buf + i * 8) == cur) { idx = i; }
        i = i + 1;
    }
    var next = 0;
    if (idx == (0 - 1)) {
        if (backward == 0) { next = load64(buf); }
        if (backward != 0) { next = load64(buf + (count - 1) * 8); }
    }
    if (idx != (0 - 1)) {
        var ni = idx + 1;
        if (backward != 0) { ni = idx - 1; }
        if (ni >= count) { ni = 0; }
        if (ni < 0) { ni = count - 1; }
        next = load64(buf + ni * 8);
    }
    dh_focus_set(next);
    return DHANCHA_OK;
}

# True if `k` is an activation key (Enter / Return / Space).
fn dh_key_is_activate(k): i64 {
    if (k == DH_KEY_ENTER)  { return 1; }
    if (k == DH_KEY_RETURN) { return 1; }
    if (k == DH_KEY_SPACE)  { return 1; }
    return 0;
}

# ---- drag-drop state machine ---------------------------------------

# |x| — for the Manhattan drag-threshold test.
fn dh_abs(x): i64 {
    if (x < 0) { return 0 - x; }
    return x;
}

# Emit a synthetic drag event (DRAG_START / _MOVE / _DROP / _END): `target`
# receives it, with the drag `source` in DH_E_SOURCE and the current pointer
# in (a, b). Propagates like any other event.
fn dh_emit_drag(target, kind, source): i64 {
    if (target == 0) { return DHANCHA_OK; }
    var ev = dh_event_new(kind);
    store64(ev + DH_E_TARGET, target);
    store64(ev + DH_E_SOURCE, source);
    store64(ev + DH_E_A, _dh_ptr_x);
    store64(ev + DH_E_B, _dh_ptr_y);
    dh_propagate(target, ev);
    return DHANCHA_OK;
}

# Advance the drag state after a POINTER_MOVE. If a draggable widget is
# pressed and the pointer has travelled past the threshold, start the drag
# (DRAG_START to the source); once dragging, every move emits DRAG_MOVE.
fn dh_drag_progress(): i64 {
    if (_dh_press == 0) { return DHANCHA_OK; }
    if (_dh_drag_src == 0) {
        if (dh_widget_is_draggable(_dh_press) == 1) {
            var dx = _dh_ptr_x - _dh_press_x;
            var dy = _dh_ptr_y - _dh_press_y;
            if (dh_abs(dx) + dh_abs(dy) >= DH_DRAG_THRESHOLD) {
                _dh_drag_src = _dh_press;
                dh_emit_drag(_dh_drag_src, DRAG_START, _dh_drag_src);
            }
        }
    } else {
        dh_emit_drag(_dh_drag_src, DRAG_MOVE, _dh_drag_src);
    }
    return DHANCHA_OK;
}

# Handle a pointer release. If a drag is in progress: drop onto the widget
# under the pointer when it is a drop target (DRAG_DROP), then always fire
# DRAG_END to the source. Otherwise it's a click — a release on the pressed
# widget synthesizes ACTIVATE. Clears press / drag state either way.
fn dh_pointer_release(target): i64 {
    if (_dh_drag_src != 0) {
        if (target != 0) {
            if (dh_widget_is_drop_target(target) == 1) {
                dh_emit_drag(target, DRAG_DROP, _dh_drag_src);
            }
        }
        dh_emit_drag(_dh_drag_src, DRAG_END, _dh_drag_src);
        _dh_drag_src = 0;
    } else {
        if (target != 0) {
            if (target == _dh_press) { dh_emit(target, ACTIVATE); }
        }
    }
    _dh_press = 0;
    return DHANCHA_OK;
}

# Dispatch an event into the tree.
#   KEY   -> the focused widget; Tab / Shift-Tab (a==DH_KEY_TAB, b!=0 =>
#            backward) instead moves focus and is toolkit-consumed;
#            Enter/Return/Space on a focused BUTTON also synthesizes ACTIVATE.
#   FOCUS -> the focused widget.
#   POINTER_MOVE -> updates the tracked pointer position, hit-tests there,
#            and emits POINTER_ENTER/LEAVE on hover boundary crossings.
#   POINTER_BTN  -> hit-tests at the tracked position; a press records the
#            press target + origin + click-to-focus; a release either DROPS
#            an in-progress drag or (if none) synthesizes ACTIVATE on the
#            pressed widget (a click).
#   DRAG  -> hit-tests at the tracked position.
# The resolved target is stamped into ev, then the raw event PROPAGATES
# (capture root->target, then bubble target->root). Higher-level events
# (ENTER/LEAVE, ACTIVATE, DRAG_START/MOVE/DROP/END) are synthesized around
# it. Returns DHANCHA_OK.
fn dh_dispatch(root, ev): i64 {
    if (root == 0) { return DHANCHA_ERR_BAD_WIDGET; }
    if (ev == 0)   { return DHANCHA_ERR_OTHER; }
    var kind = dh_event_kind(ev);

    # Tab traversal is a toolkit-level action: retarget focus, do not route
    # to the (old) focused widget, and consume the key.
    if (kind == KEY) {
        if (dh_event_a(ev) == DH_KEY_TAB) {
            dh_focus_advance(root, dh_event_b(ev));
            store64(ev + DH_E_TARGET, dh_focus_get());
            store64(ev + DH_E_CONSUMED, 1);
            return DHANCHA_OK;
        }
    }

    var target = 0;
    if (kind == KEY)   { target = dh_focus_get(); }
    if (kind == FOCUS) { target = dh_focus_get(); }
    if (kind == POINTER_MOVE) {
        _dh_ptr_x = dh_event_a(ev);
        _dh_ptr_y = dh_event_b(ev);
        target = dh_hit_test(root, _dh_ptr_x, _dh_ptr_y);
        dh_update_hover(target);
    }
    if (kind == POINTER_BTN) {
        target = dh_hit_test(root, _dh_ptr_x, _dh_ptr_y);
        if (dh_event_b(ev) == 1) {
            _dh_press = target;
            _dh_press_x = _dh_ptr_x;
            _dh_press_y = _dh_ptr_y;
            _dh_drag_src = 0;
            if (target != 0) {
                if (dh_widget_focusable(target) == 1) { dh_focus_set(target); }
            }
        }
    }
    if (kind == DRAG) { target = dh_hit_test(root, _dh_ptr_x, _dh_ptr_y); }

    store64(ev + DH_E_TARGET, target);
    dh_propagate(target, ev);

    # higher-level synthesis, AFTER the raw event has been delivered
    if (kind == POINTER_MOVE) { dh_drag_progress(); }
    if (kind == POINTER_BTN) {
        if (dh_event_b(ev) == 0) { dh_pointer_release(target); }
    }
    if (kind == KEY) {
        if (target != 0) {
            if (dh_widget_kind(target) == BUTTON) {
                if (dh_key_is_activate(dh_event_a(ev)) == 1) { dh_emit(target, ACTIVATE); }
            }
        }
    }
    return DHANCHA_OK;
}

# ---- event queue (the dh_run pump source) --------------------------
#
# A DhQueue is a fixed-capacity ring of DhEvent pointers. The future
# compositor-fd translator pushes wire events here; dh_run pops +
# dispatches. A ring (not a growable vec) so an input flood DROPS the
# overflow rather than growing without bound (puka's kq-ring discipline).
#
# DhQueue struct layout (32 bytes):
#   +0:  head   — index of the next event to pop
#   +8:  count  — number of queued events
#   +16: cap    — ring capacity (slots)
#   +24: buf    — cap i64 slots of DhEvent*
enum DhQueueField {
    DH_Q_HEAD  = 0;
    DH_Q_COUNT = 8;
    DH_Q_CAP   = 16;
    DH_Q_BUF   = 24;
}

# Allocate a ring of `cap` DhEvent-pointer slots. Returns a DhQueue* (or
# 0 for cap <= 0 / on OOM).
fn dh_queue_new(cap): i64 {
    if (cap <= 0) { return 0; }
    var q = alloc(32);
    var buf = alloc(cap * 8);
    store64(q + DH_Q_HEAD, 0);
    store64(q + DH_Q_COUNT, 0);
    store64(q + DH_Q_CAP, cap);
    store64(q + DH_Q_BUF, buf);
    return q;
}

fn dh_queue_count(q): i64 { return load64(q + DH_Q_COUNT); }
fn dh_queue_empty(q): i64 {
    if (load64(q + DH_Q_COUNT) == 0) { return 1; }
    return 0;
}

# Push `ev` onto the tail. Returns DHANCHA_OK; DHANCHA_ERR_OTHER if `ev`
# is null or the ring is full (in both cases nothing is enqueued). A null
# event is rejected here so dh_run's drain can treat a null pop strictly
# as "ring empty" (a null slot mid-ring would otherwise truncate the drain).
fn dh_queue_push(q, ev): i64 {
    if (q == 0)  { return DHANCHA_ERR_OTHER; }
    if (ev == 0) { return DHANCHA_ERR_OTHER; }
    var count = load64(q + DH_Q_COUNT);
    var cap = load64(q + DH_Q_CAP);
    if (count >= cap) { return DHANCHA_ERR_OTHER; }
    var head = load64(q + DH_Q_HEAD);
    var buf = load64(q + DH_Q_BUF);
    var idx = (head + count) % cap;
    store64(buf + idx * 8, ev);
    store64(q + DH_Q_COUNT, count + 1);
    return DHANCHA_OK;
}

# Pop from the head. Returns a DhEvent*, or 0 if the ring is empty.
fn dh_queue_pop(q): i64 {
    if (q == 0) { return 0; }
    var count = load64(q + DH_Q_COUNT);
    if (count == 0) { return 0; }
    var head = load64(q + DH_Q_HEAD);
    var cap = load64(q + DH_Q_CAP);
    var buf = load64(q + DH_Q_BUF);
    var ev = load64(buf + head * 8);
    store64(q + DH_Q_HEAD, (head + 1) % cap);
    store64(q + DH_Q_COUNT, count - 1);
    return ev;
}

# ---- event loop ----------------------------------------------------

# Stop the running dh_run loop (a handler calls this to quit the app).
fn dh_quit(): i64 { _dh_running = 0; return DHANCHA_OK; }

# The client event loop. Pops events off `q` and dispatches each into
# `root` until the queue drains or a handler calls dh_quit. Returns the
# count of events processed (>= 0), or -1 if `root` / `q` is null (a
# negative return means "did not run" — it can never be a real count).
#
# Termination is on queue-EMPTY, not on a null pop: dh_queue_push rejects
# null events, so the ring never holds a 0 slot, but keying off emptiness
# is the self-evidently-correct condition regardless.
#
# The compositor-connected loop (block on the native protocol fd, decode wire
# events into DhEvents, run layout + present when dirty) replaces the
# empty-check branch with an fd wait; the dispatch core is the same.
fn dh_run(root, q): i64 {
    if (root == 0) { return 0 - 1; }
    if (q == 0)    { return 0 - 1; }
    _dh_running = 1;
    var n = 0;
    while (_dh_running == 1) {
        if (dh_queue_empty(q) == 1) {
            _dh_running = 0;
        } else {
            var ev = dh_queue_pop(q);
            if (ev != 0) {
                dh_dispatch(root, ev);
                n = n + 1;
            }
        }
    }
    return n;
}

# --- theme.cyr ---

# theme.cyr — dhancha's binding to rupa, the shared desktop theme-token core.
#
# Widgets + chrome draw with the active MUDRA / SHANTA theme instead of hardcoded
# colours. Each helper packs a rupa 0xRRGGBB token (of the SINGLE active theme) into
# a sadish colour via sd_rgb, so an app just reads them: set a widget background with
# dh_widget_set_bg(w, dh_theme_panel()), or let dh_surface_render use the theme
# backdrop / border / text automatically. rupa is the ONE source shared with the
# compositor (aethersafha), so the toolkit matches the desktop chrome. Switch the
# whole desktop's look with rupa_theme_set_active_name("shanta-dark") etc.

# Pack a rupa 0xRRGGBB token into a sadish colour (0x00RRGGBB, the SdSurface format).
fn dh_theme_col(c): i64 { return sd_rgb(rupa_color_r(c), rupa_color_g(c), rupa_color_b(c)); }

fn dh_theme_bg(): i64     { return dh_theme_col(rupa_theme_bg(rupa_theme_active())); }
fn dh_theme_panel(): i64  { return dh_theme_col(rupa_theme_panel(rupa_theme_active())); }
fn dh_theme_widget(): i64 { return dh_theme_col(rupa_theme_widget(rupa_theme_active())); }
fn dh_theme_line(): i64   { return dh_theme_col(rupa_theme_line(rupa_theme_active())); }
fn dh_theme_ink(): i64    { return dh_theme_col(rupa_theme_ink(rupa_theme_active())); }
fn dh_theme_mute(): i64   { return dh_theme_col(rupa_theme_mute(rupa_theme_active())); }
fn dh_theme_accent(): i64 { return dh_theme_col(rupa_theme_accent(rupa_theme_active())); }
fn dh_theme_alert(): i64  { return dh_theme_col(rupa_theme_alert(rupa_theme_active())); }

# --- surface.cyr ---

# @public — dhancha client surface / present path.
# surface.cyr — DhSurface: a client window backed by a pixel buffer.
#
# A DhSurface is the app's window from the client's side: a CPU pixel
# buffer the toolkit draws the widget tree into, then presents to the
# aethersafha compositor as a client surface over the native protocol (which the
# compositor composites onto the screen). v0.1.0 allocates the buffer;
# the draw + present code lands in v0.2 once sadish / rekha / mabda are
# wired.
#
# DhSurface struct layout (40 bytes):
#   +0:  width   — surface width in pixels
#   +8:  height  — surface height in pixels
#   +16: pixels  — owned RGBA8 buffer (width*height*4 bytes), or 0
#   +24: root    — the DhWidget tree root drawn into this surface (or 0)
#   +32: dirty   — 1 if the buffer needs a redraw before next present
enum DhSurfaceField {
    DH_S_WIDTH  = 0;
    DH_S_HEIGHT = 8;
    DH_S_PIXELS = 16;
    DH_S_ROOT   = 24;
    DH_S_DIRTY  = 32;
}

# Allocate a DhSurface with a w×h RGBA8 pixel buffer. Returns a
# DhSurface* (or 0 on OOM — the caller can map that to
# DHANCHA_ERR_NO_SURFACE / _OOM).
fn dh_surface_new(w, h): i64 {
    if (w <= 0) { return 0; }
    if (h <= 0) { return 0; }
    var surf = alloc(40);
    var buf = alloc(w * h * 4);
    store64(surf + DH_S_WIDTH, w);
    store64(surf + DH_S_HEIGHT, h);
    store64(surf + DH_S_PIXELS, buf);
    store64(surf + DH_S_ROOT, 0);
    store64(surf + DH_S_DIRTY, 1);
    return surf;
}

fn dh_surface_width(surf): i64  { return load64(surf + DH_S_WIDTH); }
fn dh_surface_height(surf): i64 { return load64(surf + DH_S_HEIGHT); }
fn dh_surface_pixels(surf): i64 { return load64(surf + DH_S_PIXELS); }
fn dh_surface_root(surf): i64   { return load64(surf + DH_S_ROOT); }

# Attach the widget-tree root that this surface renders.
fn dh_surface_set_root(surf, root): i64 {
    if (surf == 0) { return DHANCHA_ERR_NO_SURFACE; }
    store64(surf + DH_S_ROOT, root);
    store64(surf + DH_S_DIRTY, 1);
    return DHANCHA_OK;
}

# Present the surface to the compositor. In the full toolkit this runs
# layout (if dirty), draws the widget tree into `pixels`, and hands the
# buffer to aethersafha as a client surface over the native protocol. Returns
# DHANCHA_OK / an error code.
#
# TODO (see CHANGELOG): the present path — a CPU buffer submit over the native
# protocol (mabda GPU upload later). The CPU draw shipped in 0.2.0 as
# dh_surface_render (below); this entry point validates the surface and
# clears the dirty flag.
fn dh_surface_present(surf): i64 {
    if (surf == 0) { return DHANCHA_ERR_NO_SURFACE; }
    if (dh_surface_pixels(surf) == 0) { return DHANCHA_ERR_NO_SURFACE; }
    # TODO (see CHANGELOG): CPU buffer submit over the native protocol to aethersafha (mabda GPU upload later).
    # The CPU render is dh_surface_render (below); wiring its SdSurface here +
    # the compositor commit is the present-integration work.
    store64(surf + DH_S_DIRTY, 0);
    return DHANCHA_OK;
}

# ---- widget-tree draw (sadish fills/strokes + rekha text) ----------

# Draw `text` (a cstring) left-aligned inside a box at (x, y) of height h, onto
# the sadish surface `sds`, using `font` (a RekhaFont). Each glyph is converted
# to a sadish path (scaled so the em-height ~= h) and union-filled into one
# coverage canvas, then blit as white. Advance is a fixed ~0.6em (real hmtx
# advances are a rekha v0.4 item). No-op if font is 0.
fn dh_draw_text(sds, font, text, x, y, h): i64 {
    if (text == 0) { return 0; }
    if (font == 0) {
        # Bitmap path: blit the kashi VGA 8x16 SYSTEM font (full CP437, crisp +
        # monospace, matching the compositor chrome) directly into the sadish
        # surface. rekha (font != 0) stays for scalable TrueType when a .ttf loads.
        kashi_font_init();
        var sw = sd_surface_width(sds);
        var sh2 = sd_surface_height(sds);
        var pix = sd_surface_pixels(sds);
        var ink = dh_theme_ink();              # text in the active theme's primary-ink colour
        var ky = y + (h - 16) / 2;             # vertically centre the 16px glyph in the box
        var kx = x + 3;
        var ki = 0;
        while (load8(text + ki) != 0) {
            var kc = load8(text + ki);
            var kr = 0;
            while (kr < 16) {
                var kb = kashi_glyph_row(0, kc, kr);   # KASHI_FONT_VGA_8X16 = 0; one row byte
                var kcol = 0;
                while (kcol < 8) {
                    if ((kb & (1 << (7 - kcol))) != 0) {
                        var px = kx + kcol; var py = ky + kr;
                        if (px >= 0) { if (px < sw) { if (py >= 0) { if (py < sh2) {
                                        store32(pix + (py * sw + px) * 4, ink);   # theme ink (0x00RRGGBB == BGRA)
                                    } } } }
                    }
                    kcol = kcol + 1;
                }
                kr = kr + 1;
            }
            kx = kx + 9;                        # 8px glyph + 1px gap (monospace)
            ki = ki + 1;
        }
        return 0;
    }
    var upem = rekha_units_per_em(font);
    if (upem <= 0) { return 0; }
    var scale = (h << 16) / upem;          # 16.16 pixels per design unit
    var advf = (h * 6) / 10;               # fixed advance ~0.6 em
    if (advf <= 0) { advf = 4; }
    var baseline = y + h - 2;              # sit text near the box bottom
    var cx = x + 2;

    var cv = sd_canvas_new(sd_surface_width(sds), sd_surface_height(sds));
    var i = 0;
    while (load8(text + i) != 0) {
        var cp = load8(text + i);
        if (cp != 32) {                    # spaces contribute no coverage
            var path = rekha_char_to_sdpath(font, cp, scale, cx << 16, baseline << 16);
            sd_canvas_fill_union(cv, path, SD_FILL_NONZERO);
        }
        cx = cx + advf;
        i = i + 1;
    }
    sd_canvas_blit(cv, sds, sd_rgb(255, 255, 255));
    return 0;
}

# Draw one widget (background, border, text) onto `sds`, then recurse into its
# children. `font` may be 0 (text skipped).
fn dh_draw_widget(sds, wgt, font): i64 {
    var x = dh_widget_x(wgt);
    var y = dh_widget_y(wgt);
    var w = dh_widget_w(wgt);
    var h = dh_widget_h(wgt);
    var bg = dh_widget_bg(wgt);
    if (bg != (0 - 1)) {
        sd_fill_rect(sds, x, y, w, h, bg);
    }
    if (dh_widget_kind(wgt) == BUTTON) {
        sd_rect(sds, x, y, w, h, dh_theme_line());   # 1px border in the theme's line colour
    }
    var text = dh_widget_text(wgt);
    if (text != 0) {
        dh_draw_text(sds, font, text, x, y, h);
    }
    var child = dh_widget_first_child(wgt);
    while (child != 0) {
        dh_draw_widget(sds, child, font);
        child = dh_widget_next_sibling(child);
    }
    return 0;
}

# @public — render `surf`'s widget tree into a fresh sadish SdSurface and
# return it (BGRA pixels; the caller can present/PPM it). `font` may be 0.
# Returns 0 on a bad surface.
fn dh_surface_render(surf, font): i64 {
    if (surf == 0) { return 0; }
    var w = dh_surface_width(surf);
    var h = dh_surface_height(surf);
    var sds = sd_surface_new(w, h);
    sd_clear(sds, dh_theme_bg());          # the active rupa theme's desktop void
    var root = dh_surface_root(surf);
    if (root != 0) {
        dh_draw_widget(sds, root, font);
    }
    return sds;
}
