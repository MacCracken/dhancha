# programs/layout_test.cyr — RUN test for box layout (BOX_V / BOX_H stacking).
# Exit code = failed checks.

include "src/lib.cyr"

var g_fails = 0;

fn check(got, want): i64 {
    if (got == want) { return 0; }
    g_fails = g_fails + 1;
    return 1;
}

fn main(): i64 {
    alloc_init();

    # BOX_V: root 100x100, children pref-height 30 then 40
    var root = dh_widget_new(WINDOW);
    dh_widget_set_layout(root, BOX_V);
    var c0 = dh_widget_new(BOX);
    dh_widget_set_pref(c0, 0, 30);
    var c1 = dh_widget_new(BOX);
    dh_widget_set_pref(c1, 0, 40);
    dh_widget_add_child(root, c0);
    dh_widget_add_child(root, c1);
    dh_layout_apply(root, 100, 100);
    check(dh_widget_w(root), 100);
    check(dh_widget_h(root), 100);
    check(dh_widget_x(c0), 0);
    check(dh_widget_y(c0), 0);
    check(dh_widget_w(c0), 100);
    check(dh_widget_h(c0), 30);
    check(dh_widget_x(c1), 0);
    check(dh_widget_y(c1), 30);      # stacked below c0
    check(dh_widget_w(c1), 100);
    check(dh_widget_h(c1), 40);

    # BOX_H: root 200x50, children pref-width 60 then 80
    var r2 = dh_widget_new(WINDOW);
    dh_widget_set_layout(r2, BOX_H);
    var d0 = dh_widget_new(BOX);
    dh_widget_set_pref(d0, 60, 0);
    var d1 = dh_widget_new(BOX);
    dh_widget_set_pref(d1, 80, 0);
    dh_widget_add_child(r2, d0);
    dh_widget_add_child(r2, d1);
    dh_layout_apply(r2, 200, 50);
    check(dh_widget_x(d0), 0);
    check(dh_widget_w(d0), 60);
    check(dh_widget_h(d0), 50);      # full height
    check(dh_widget_x(d1), 60);      # stacked right of d0
    check(dh_widget_w(d1), 80);
    check(dh_widget_h(d1), 50);

    # --- padding + gap: BOX_V pad=10 gap=5, two 20-tall children ---
    var rp = dh_widget_new(WINDOW);
    dh_widget_set_layout(rp, BOX_V);
    dh_widget_set_padding(rp, 10);
    dh_widget_set_gap(rp, 5);
    var p0 = dh_widget_new(BOX);
    dh_widget_set_pref(p0, 0, 20);
    var p1 = dh_widget_new(BOX);
    dh_widget_set_pref(p1, 0, 20);
    dh_widget_add_child(rp, p0);
    dh_widget_add_child(rp, p1);
    dh_layout_apply(rp, 100, 100);
    check(dh_widget_x(p0), 10);      # inset by pad
    check(dh_widget_y(p0), 10);
    check(dh_widget_w(p0), 80);      # 100 - 2*pad
    check(dh_widget_h(p0), 20);
    check(dh_widget_y(p1), 35);      # 10 + 20 + 5 gap
    check(dh_widget_w(p1), 80);

    # --- flex: BOX_V height 100, f0 flex=1 + f1 flex=1 -> 50/50 ---
    var rf = dh_widget_new(WINDOW);
    dh_widget_set_layout(rf, BOX_V);
    var f0 = dh_widget_new(BOX);
    dh_widget_set_flex(f0, 1);
    var f1 = dh_widget_new(BOX);
    dh_widget_set_flex(f1, 1);
    dh_widget_add_child(rf, f0);
    dh_widget_add_child(rf, f1);
    dh_layout_apply(rf, 100, 100);
    check(dh_widget_h(f0), 50);
    check(dh_widget_y(f1), 50);
    check(dh_widget_h(f1), 50);

    # --- weighted flex + last-child remainder: 1 vs 2 over 100 ---
    var rw2 = dh_widget_new(WINDOW);
    dh_widget_set_layout(rw2, BOX_V);
    var w0 = dh_widget_new(BOX);
    dh_widget_set_flex(w0, 1);
    var w1 = dh_widget_new(BOX);
    dh_widget_set_flex(w1, 2);
    dh_widget_add_child(rw2, w0);
    dh_widget_add_child(rw2, w1);
    dh_layout_apply(rw2, 100, 100);
    check(dh_widget_h(w0), 33);      # floor(100*1/3)
    check(dh_widget_h(w1), 67);      # exact remainder (33+67=100, no lost px)
    check(dh_widget_y(w1), 33);

    # --- mixed fixed + flex: fixed 20 then flex fills the rest ---
    var rm = dh_widget_new(WINDOW);
    dh_widget_set_layout(rm, BOX_V);
    var m0 = dh_widget_new(BOX);
    dh_widget_set_pref(m0, 0, 20);   # fixed 20
    var m1 = dh_widget_new(BOX);
    dh_widget_set_flex(m1, 1);       # flexible
    dh_widget_add_child(rm, m0);
    dh_widget_add_child(rm, m1);
    dh_layout_apply(rm, 100, 100);
    check(dh_widget_h(m0), 20);
    check(dh_widget_y(m1), 20);
    check(dh_widget_h(m1), 80);      # 100 - 20

    # --- cross-axis align in BOX_V (cross = width), pref_w 40 in a 100 box ---
    var ra = dh_widget_new(WINDOW);
    dh_widget_set_layout(ra, BOX_V);
    var a_st = dh_widget_new(BOX);   # STRETCH (default): fills width
    dh_widget_set_pref(a_st, 40, 10);
    var a_ce = dh_widget_new(BOX);   # CENTER
    dh_widget_set_pref(a_ce, 40, 10);
    dh_widget_set_align(a_ce, ALIGN_CENTER);
    var a_en = dh_widget_new(BOX);   # END
    dh_widget_set_pref(a_en, 40, 10);
    dh_widget_set_align(a_en, ALIGN_END);
    dh_widget_add_child(ra, a_st);
    dh_widget_add_child(ra, a_ce);
    dh_widget_add_child(ra, a_en);
    dh_layout_apply(ra, 100, 100);
    check(dh_widget_x(a_st), 0);     # stretch ignores pref_w
    check(dh_widget_w(a_st), 100);
    check(dh_widget_x(a_ce), 30);    # (100-40)/2
    check(dh_widget_w(a_ce), 40);
    check(dh_widget_x(a_en), 60);    # 100-40
    check(dh_widget_w(a_en), 40);

    # --- BOX_H cross-axis align (cross = height): CENTER a 20-tall child ---
    var rz = dh_widget_new(WINDOW);
    dh_widget_set_layout(rz, BOX_H);
    var z_ce = dh_widget_new(BOX);
    dh_widget_set_pref(z_ce, 30, 20);
    dh_widget_set_align(z_ce, ALIGN_CENTER);
    dh_widget_add_child(rz, z_ce);
    dh_layout_apply(rz, 200, 50);
    check(dh_widget_x(z_ce), 0);
    check(dh_widget_w(z_ce), 30);
    check(dh_widget_y(z_ce), 15);    # (50-20)/2
    check(dh_widget_h(z_ce), 20);

    # --- BOX_H flex on a NON-square container: pins the row main-axis so a
    #     main/cross axis swap can't hide behind a square box ---
    var rhf = dh_widget_new(WINDOW);
    dh_widget_set_layout(rhf, BOX_H);
    var hf0 = dh_widget_new(BOX);
    dh_widget_set_flex(hf0, 1);
    var hf1 = dh_widget_new(BOX);
    dh_widget_set_flex(hf1, 1);
    dh_widget_add_child(rhf, hf0);
    dh_widget_add_child(rhf, hf1);
    dh_layout_apply(rhf, 100, 40);   # wide, not square
    check(dh_widget_w(hf0), 50);     # flex splits WIDTH (a row's main axis)
    check(dh_widget_h(hf0), 40);     # stretch fills the 40 height
    check(dh_widget_x(hf1), 50);
    check(dh_widget_w(hf1), 50);
    check(dh_widget_h(hf1), 40);

    # ================================================================
    # Intrinsic measure (natural content size, bottom-up)
    # ================================================================
    var mout = alloc(16);

    # --- leaf: natural size == pref ---
    var leaf = dh_widget_new(BOX);
    dh_widget_set_pref(leaf, 30, 20);
    dh_measure(leaf, mout);
    check(load64(mout), 30);
    check(load64(mout + 8), 20);
    check(dh_measure_w(leaf), 30);
    check(dh_measure_h(leaf), 20);

    # --- BOX_V (pad 5, gap 4): w = max(30,50)+2*5 = 60; h = (20+10)+4+2*5 = 44 ---
    var mv = dh_widget_new(WINDOW);
    dh_widget_set_layout(mv, BOX_V);
    dh_widget_set_padding(mv, 5);
    dh_widget_set_gap(mv, 4);
    var mv0 = dh_widget_new(BOX);
    dh_widget_set_pref(mv0, 30, 20);
    var mv1 = dh_widget_new(BOX);
    dh_widget_set_pref(mv1, 50, 10);
    dh_widget_add_child(mv, mv0);
    dh_widget_add_child(mv, mv1);
    dh_measure(mv, mout);
    check(load64(mout), 60);
    check(load64(mout + 8), 44);

    # --- BOX_H: w = 30+50 = 80; h = max(20,10) = 20 ---
    var mh = dh_widget_new(WINDOW);
    dh_widget_set_layout(mh, BOX_H);
    var mh0 = dh_widget_new(BOX);
    dh_widget_set_pref(mh0, 30, 20);
    var mh1 = dh_widget_new(BOX);
    dh_widget_set_pref(mh1, 50, 10);
    dh_widget_add_child(mh, mh0);
    dh_widget_add_child(mh, mh1);
    dh_measure(mh, mout);
    check(load64(mout), 80);
    check(load64(mout + 8), 20);

    # --- nested: BOX_V > [ inner(BOX_H 20+25 x 15), leaf 10x8 ] ---
    var mn = dh_widget_new(WINDOW);
    dh_widget_set_layout(mn, BOX_V);
    var inner = dh_widget_new(BOX);
    dh_widget_set_layout(inner, BOX_H);
    var in0 = dh_widget_new(BOX);
    dh_widget_set_pref(in0, 20, 15);
    var in1 = dh_widget_new(BOX);
    dh_widget_set_pref(in1, 25, 15);
    dh_widget_add_child(inner, in0);
    dh_widget_add_child(inner, in1);
    var leaf2 = dh_widget_new(BOX);
    dh_widget_set_pref(leaf2, 10, 8);
    dh_widget_add_child(mn, inner);
    dh_widget_add_child(mn, leaf2);
    dh_measure(mn, mout);
    check(load64(mout), 45);         # max(inner 45, leaf 10)
    check(load64(mout + 8), 23);     # inner 15 + leaf 8

    # --- dh_layout_fit + auto-size: inner (pref 0) fits its measured content ---
    dh_layout_fit(mn);
    check(dh_widget_w(mn), 45);
    check(dh_widget_h(mn), 23);
    check(dh_widget_y(inner), 0);
    check(dh_widget_h(inner), 15);   # auto-sized: pref_h was 0 -> measured 15
    check(dh_widget_y(leaf2), 15);   # stacked below the auto-sized inner
    check(dh_widget_h(leaf2), 8);

    # --- fit with a fixed child container carrying its OWN pref main size:
    #     measure honors the pref, so the parent contains it (no overflow) ---
    var rfx = dh_widget_new(WINDOW);
    dh_widget_set_layout(rfx, BOX_V);
    var cfx = dh_widget_new(BOX);
    dh_widget_set_layout(cfx, BOX_V);
    dh_widget_set_pref(cfx, 0, 100);   # explicit height 100...
    var lfx = dh_widget_new(BOX);
    dh_widget_set_pref(lfx, 30, 20);   # ...over only 20 of content
    dh_widget_add_child(cfx, lfx);
    dh_widget_add_child(rfx, cfx);
    dh_measure(rfx, mout);
    check(load64(mout + 8), 100);      # parent measures to the child's pref, not its content
    dh_layout_fit(rfx);
    check(dh_widget_h(rfx), 100);
    check(dh_widget_h(cfx), 100);      # child fits inside the parent (no spill)

    if (g_fails == 0) {
        var ok = "layout_test: PASS (box stacking, padding, gap, flex, align, measure, fit)\n";
        syscall(1, 1, ok, strlen(ok));
    } else {
        var bad = "layout_test: FAIL\n";
        syscall(1, 2, bad, strlen(bad));
    }
    return g_fails;
}

var exit_code = main();
syscall(60, exit_code);
